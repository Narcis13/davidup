{
  "id": "before-after",
  "name": "Before & After",
  "description": "Side-by-side comparison with before and after images",
  "platform": "universal",
  "style": "professional",
  "variables": [
    { "name": "beforeImage", "description": "URL to before image", "type": "url" },
    { "name": "afterImage", "description": "URL to after image", "type": "url" },
    { "name": "title", "description": "Title or description", "type": "text" },
    { "name": "backgroundColor", "description": "Background color", "type": "color", "default": "#0a0a0a" }
  ],
  "spec": {
    "output": {
      "width": 1080,
      "height": 1080,
      "fps": 30,
      "duration": 4
    },
    "scenes": [
      {
        "id": "scene-1-before",
        "name": "Before",
        "duration": 2,
        "background": "{{backgroundColor}}",
        "elements": [
          {
            "type": "image",
            "src": "{{beforeImage}}",
            "x": 90,
            "y": 190,
            "width": 900,
            "height": 700,
            "fit": "cover",
            "borderRadius": 20
          },
          {
            "type": "shape",
            "shape": "rectangle",
            "x": 90,
            "y": 790,
            "width": 200,
            "height": 60,
            "fill": "#e74c3c",
            "borderRadius": 8
          },
          {
            "type": "text",
            "text": "BEFORE",
            "x": 190,
            "y": 832,
            "fontSize": 28,
            "fontWeight": 700,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter"
          },
          {
            "type": "text",
            "text": "{{title}}",
            "x": 540,
            "y": 100,
            "fontSize": 48,
            "fontWeight": 600,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 900
          }
        ],
        "transition": {
          "type": "slide",
          "duration": 0.5,
          "direction": "left",
          "easing": "easeInOut"
        }
      },
      {
        "id": "scene-2-after",
        "name": "After",
        "duration": 2,
        "background": "{{backgroundColor}}",
        "elements": [
          {
            "type": "image",
            "src": "{{afterImage}}",
            "x": 90,
            "y": 190,
            "width": 900,
            "height": 700,
            "fit": "cover",
            "borderRadius": 20
          },
          {
            "type": "shape",
            "shape": "rectangle",
            "x": 790,
            "y": 790,
            "width": 200,
            "height": 60,
            "fill": "#27ae60",
            "borderRadius": 8
          },
          {
            "type": "text",
            "text": "AFTER",
            "x": 890,
            "y": 832,
            "fontSize": 28,
            "fontWeight": 700,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter"
          },
          {
            "type": "text",
            "text": "{{title}}",
            "x": 540,
            "y": 100,
            "fontSize": 48,
            "fontWeight": 600,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 900
          }
        ]
      }
    ]
  }
}
