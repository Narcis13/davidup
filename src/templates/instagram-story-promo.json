{
  "id": "instagram-story-promo",
  "name": "Instagram Story Promo",
  "description": "Playful promotional story with headline and CTA",
  "platform": "instagram",
  "style": "playful",
  "variables": [
    { "name": "headline", "description": "Main headline text", "type": "text" },
    { "name": "backgroundImage", "description": "URL to background image", "type": "url" },
    { "name": "ctaText", "description": "Call-to-action button text", "type": "text" },
    { "name": "accentColor", "description": "Accent color for CTA", "type": "color", "default": "#ff6b9d" }
  ],
  "spec": {
    "output": {
      "width": 1080,
      "height": 1080,
      "fps": 30,
      "duration": 4
    },
    "scenes": [
      {
        "id": "scene-1-headline",
        "name": "Headline Reveal",
        "duration": 2,
        "background": "#1a1a1a",
        "elements": [
          {
            "type": "image",
            "src": "{{backgroundImage}}",
            "x": 0,
            "y": 0,
            "width": 1080,
            "height": 1080,
            "fit": "cover",
            "opacity": 0.4
          },
          {
            "type": "text",
            "text": "{{headline}}",
            "x": 540,
            "y": 540,
            "fontSize": 72,
            "fontWeight": 800,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 900,
            "shadow": {
              "color": "#000000",
              "blur": 20,
              "offsetX": 0,
              "offsetY": 4
            }
          }
        ],
        "transition": {
          "type": "zoom",
          "duration": 0.4,
          "easing": "easeOutBounce"
        }
      },
      {
        "id": "scene-2-cta",
        "name": "CTA",
        "duration": 2,
        "background": "#1a1a1a",
        "elements": [
          {
            "type": "image",
            "src": "{{backgroundImage}}",
            "x": 0,
            "y": 0,
            "width": 1080,
            "height": 1080,
            "fit": "cover",
            "opacity": 0.3
          },
          {
            "type": "text",
            "text": "{{headline}}",
            "x": 540,
            "y": 400,
            "fontSize": 56,
            "fontWeight": 700,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 900
          },
          {
            "type": "shape",
            "shape": "rectangle",
            "x": 240,
            "y": 580,
            "width": 600,
            "height": 100,
            "fill": "{{accentColor}}",
            "borderRadius": 50
          },
          {
            "type": "text",
            "text": "{{ctaText}}",
            "x": 540,
            "y": 645,
            "fontSize": 40,
            "fontWeight": 700,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter"
          }
        ]
      }
    ]
  }
}
