{
  "id": "countdown-timer",
  "name": "Countdown Timer",
  "description": "Energetic countdown display for events and launches",
  "platform": "universal",
  "style": "energetic",
  "variables": [
    { "name": "eventName", "description": "Name of the event", "type": "text" },
    { "name": "countdownText", "description": "Countdown display text (e.g. 3 DAYS LEFT)", "type": "text" },
    { "name": "backgroundColor", "description": "Background color", "type": "color", "default": "#2d1b4e" }
  ],
  "spec": {
    "output": {
      "width": 1080,
      "height": 1080,
      "fps": 30,
      "duration": 5
    },
    "scenes": [
      {
        "id": "scene-1-countdown",
        "name": "Countdown Display",
        "duration": 5,
        "background": "{{backgroundColor}}",
        "elements": [
          {
            "type": "shape",
            "shape": "circle",
            "x": 540,
            "y": 540,
            "radius": 350,
            "fill": {
              "type": "radial",
              "stops": [
                { "offset": 0, "color": "#ff6b6b" },
                { "offset": 1, "color": "#4ecdc4" }
              ]
            },
            "opacity": 0.2
          },
          {
            "type": "shape",
            "shape": "circle",
            "x": 540,
            "y": 540,
            "radius": 280,
            "stroke": {
              "color": "#ffffff",
              "width": 8
            }
          },
          {
            "type": "text",
            "text": "{{eventName}}",
            "x": 540,
            "y": 280,
            "fontSize": 42,
            "fontWeight": 600,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 800
          },
          {
            "type": "text",
            "text": "{{countdownText}}",
            "x": 540,
            "y": 560,
            "fontSize": 72,
            "fontWeight": 800,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "shadow": {
              "color": "#ff6b6b",
              "blur": 30,
              "offsetX": 0,
              "offsetY": 0
            }
          },
          {
            "type": "text",
            "text": "Stay tuned!",
            "x": 540,
            "y": 820,
            "fontSize": 32,
            "fontWeight": 400,
            "color": "#aaaaaa",
            "textAlign": "center",
            "fontFamily": "Inter"
          }
        ]
      }
    ]
  }
}
