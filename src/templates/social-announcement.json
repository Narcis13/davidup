{
  "id": "social-announcement",
  "name": "Social Announcement",
  "description": "Clean announcement template for any social platform",
  "platform": "universal",
  "style": "professional",
  "variables": [
    { "name": "headline", "description": "Main announcement headline", "type": "text" },
    { "name": "date", "description": "Event date or time", "type": "text" },
    { "name": "details", "description": "Additional details or description", "type": "text" },
    { "name": "backgroundColor", "description": "Background color", "type": "color", "default": "#1e3a5f" }
  ],
  "spec": {
    "output": {
      "width": 1080,
      "height": 1080,
      "fps": 30,
      "duration": 5
    },
    "scenes": [
      {
        "id": "scene-1-headline",
        "name": "Headline",
        "duration": 2,
        "background": "{{backgroundColor}}",
        "elements": [
          {
            "type": "shape",
            "shape": "rectangle",
            "x": 90,
            "y": 440,
            "width": 900,
            "height": 200,
            "fill": {
              "type": "linear",
              "angle": 90,
              "stops": [
                { "offset": 0, "color": "#ffffff10" },
                { "offset": 1, "color": "#ffffff00" }
              ]
            },
            "borderRadius": 20
          },
          {
            "type": "text",
            "text": "{{headline}}",
            "x": 540,
            "y": 520,
            "fontSize": 64,
            "fontWeight": 700,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 850
          },
          {
            "type": "text",
            "text": "{{date}}",
            "x": 540,
            "y": 620,
            "fontSize": 36,
            "fontWeight": 500,
            "color": "#88ccff",
            "textAlign": "center",
            "fontFamily": "Inter"
          }
        ],
        "transition": {
          "type": "fade",
          "duration": 0.5,
          "easing": "easeInOut"
        }
      },
      {
        "id": "scene-2-details",
        "name": "Details",
        "duration": 3,
        "background": "{{backgroundColor}}",
        "elements": [
          {
            "type": "text",
            "text": "{{headline}}",
            "x": 540,
            "y": 300,
            "fontSize": 48,
            "fontWeight": 600,
            "color": "#ffffff",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 900
          },
          {
            "type": "shape",
            "shape": "rectangle",
            "x": 390,
            "y": 380,
            "width": 300,
            "height": 4,
            "fill": "#88ccff"
          },
          {
            "type": "text",
            "text": "{{details}}",
            "x": 540,
            "y": 500,
            "fontSize": 36,
            "fontWeight": 400,
            "color": "#cccccc",
            "textAlign": "center",
            "fontFamily": "Inter",
            "maxWidth": 800,
            "lineHeight": 1.4
          },
          {
            "type": "text",
            "text": "{{date}}",
            "x": 540,
            "y": 750,
            "fontSize": 42,
            "fontWeight": 600,
            "color": "#88ccff",
            "textAlign": "center",
            "fontFamily": "Inter"
          }
        ]
      }
    ]
  }
}
