{
  "name": "motionforge",
  "version": "0.1.0",
  "description": "Deterministic 2D programmatic video engine with MCP tools for AI agents",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/engine/index.ts",
    "./schema": "./src/schema/index.ts",
    "./easings": "./src/easings/index.ts",
    "./assets": "./src/assets/index.ts",
    "./node": "./src/drivers/node/index.ts",
    "./browser": "./src/drivers/browser/index.ts",
    "./mcp": "./src/mcp/index.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "skia-canvas": "^3.0.8",
    "zod": "^3.23.0"
  },
  "trustedDependencies": [
    "ffmpeg-static",
    "skia-canvas"
  ]
}
