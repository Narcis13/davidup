{
  "name": "davidup",
  "version": "0.1.0",
  "description": "Deterministic 2D programmatic video engine with MCP tools for AI agents",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:browser": "vite --config examples/browser-demo/vite.config.ts",
    "build:browser": "vite build --config examples/browser-demo/vite.config.ts",
    "dev:comprehensive": "vite --config examples/comprehensive-browser/vite.config.ts",
    "build:comprehensive": "vite build --config examples/comprehensive-browser/vite.config.ts",
    "dev:comprehensive-split": "vite --config examples/comprehensive-split-browser/vite.config.ts",
    "build:comprehensive-split": "vite build --config examples/comprehensive-split-browser/vite.config.ts",
    "dev:two-templates": "vite --config examples/two-templates-browser/vite.config.ts",
    "build:two-templates": "vite build --config examples/two-templates-browser/vite.config.ts",
    "dev:four-scenes": "vite --config examples/four-scenes-browser/vite.config.ts",
    "build:four-scenes": "vite build --config examples/four-scenes-browser/vite.config.ts",
    "mcp": "bun run src/mcp/bin.ts"
  },
  "bin": {
    "davidup-mcp": "./src/mcp/bin.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/engine/index.ts",
    "./schema": "./src/schema/index.ts",
    "./easings": "./src/easings/index.ts",
    "./assets": "./src/assets/index.ts",
    "./node": "./src/drivers/node/index.ts",
    "./browser": "./src/drivers/browser/index.ts",
    "./mcp": "./src/mcp/index.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "skia-canvas": "^3.0.8",
    "zod": "^3.23.0"
  },
  "trustedDependencies": [
    "ffmpeg-static",
    "skia-canvas"
  ]
}
